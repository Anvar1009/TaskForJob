@using Entity.Models
@model Employees

<h2>Edit Employee</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div>
        <label>First Name</label>
        <input asp-for="Fore_Names" class="form-control" />
    </div>

    <div>
        <label>Surname</label>
        <input asp-for="Sur_Names" class="form-control" />
    </div>

    <div>
        <label>Date of Birth</label>
        <input asp-for="DataOfBirth" type="date" class="form-control" />
    </div>

    <div>
        <label>Telephone</label>
        <input asp-for="Telephone" class="form-control" />
    </div>

    <div>
        <label>Mobile Phone</label>
        <input asp-for="Mobile_phone" class="form-control" />
    </div>

    <div>
        <label>Address</label>
        <input asp-for="Address" class="form-control" />
    </div>

    <div>
        <label>Address 2</label>
        <input asp-for="Address_2" class="form-control" />
    </div>

    <div>
        <label>Post Code</label>
        <input asp-for="Post_Code" class="form-control" />
    </div>

    <div>
        <label>Email</label>
        <input asp-for="Email_Home" class="form-control" />
    </div>

    <div>
        <label>Start Date</label>
        <input asp-for="StartDate" type="date" class="form-control" />
    </div>

    <br />

    <button type="submit" class="btn btn-success">Save</button>
    <a href="/Home/Index" class="btn btn-secondary">Cancel</a>
</form>